{
  "name": "the-green-gauntlet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev": "concurrently -n client,server -c blue,green \"npm:dev:client\" \"npm:dev:server\"",
    "build:client": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist-server/index.js",
    "preview": "vite preview",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.server.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "perf:mock-il": "node tests/perf/mock-il/server.mjs",
    "perf:steady": "node tests/perf/run.mjs scenario-1-steady",
    "perf:thundering-herd": "node tests/perf/run.mjs scenario-2-thundering-herd",
    "perf:polling": "node tests/perf/run.mjs scenario-3-polling-fallback",
    "perf:admin-batch": "node tests/perf/run.mjs scenario-4-admin-batch",
    "perf:degraded": "node tests/perf/run.mjs scenario-5-degraded-upstream",
    "perf:bruteforce": "node tests/perf/run.mjs scenario-6-admin-bruteforce",
    "perf:soak": "node tests/perf/run.mjs scenario-7-soak"
  },
  "dependencies": {
    "@fastify/static": "^8.0.3",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
