# Set to "true" to serve synthetic leaderboard data (no ImmersiveLab calls).
# Flip to "false" and fill credentials below for real upstream.
USE_STUB_UPSTREAM=true

# ImmersiveLab API credentials — required unless USE_STUB_UPSTREAM=true.
IMMERSIVELAB_ACCESS_KEY=
IMMERSIVELAB_SECRET_TOKEN=
IMMERSIVELAB_BASE_URL=https://api.immersivelabs.online

# Event window — ISO 8601 UTC. start < end.
EVENT_START_AT=2026-05-01T09:00:00Z
EVENT_END_AT=2026-05-01T17:00:00Z

# Server runtime
PORT=3000
SNAPSHOT_TTL_MS=10000
TOKEN_REFRESH_MARGIN_S=60
DATA_DIR=./data
LOG_LEVEL=info
